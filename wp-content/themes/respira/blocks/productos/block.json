{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "respira/productos",
  "version": "1.0.0",
  "title": "Productos",
  "category": "respira",
  "icon": "cart",
  "description": "Cuadrícula de productos con imagen, título, precio y rating. Productos repetibles (catálogo estático; para tienda real usar WooCommerce).",
  "keywords": ["productos", "products", "tienda", "shop"],
  "textdomain": "respira",
  "attributes": {
    "subtitle": { "type": "string", "default": "" },
    "title":    { "type": "string", "default": "" },
    "cartUrl":  { "type": "string", "default": "" },
    "items": {
      "type": "array",
      "default": [
        { "title": "Show Piece",  "link": "", "price": "$32.00", "rating": 5, "imageId": 0, "imageUrl": "resource/products/1.jpg", "imageAlt": "" },
        { "title": "Leather Belt","link": "", "price": "$52.00", "rating": 5, "imageId": 0, "imageUrl": "resource/products/2.jpg", "imageAlt": "" },
        { "title": "Sunglasses",  "link": "", "price": "$42.00", "rating": 5, "imageId": 0, "imageUrl": "resource/products/3.jpg", "imageAlt": "" },
        { "title": "Backpack",    "link": "", "price": "$22.00", "rating": 5, "imageId": 0, "imageUrl": "resource/products/4.jpg", "imageAlt": "" }
      ]
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "spacing": { "margin": true, "padding": true }
  },
  "editorScript": "file:./index.js",
  "render": "file:render.php"
}

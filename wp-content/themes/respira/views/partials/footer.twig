{#
  Footer (portado de Realest, footer-style-one).
  Variante clara (footer-light): fondo claro y tipografia oscura.
  - Fila unica (footer-main-row): logo | contacto | menu | logos extra, en una misma linea.
  - Contacto y menu alineados a la izquierda (textos y elementos).
  - En mobile los 4 bloques se apilan uno debajo del otro.
  Los "Quick Link" usan la ubicacion de menu "footer" si esta asignada.
#}
<footer class="main-footer footer-style-one footer-light">
  <div class="shape-1"><img src="{{ theme.link }}/assets/images/abc/footer_detail.png" alt=""></div>

  <div class="widgets-section">
    <div class="anim-icon"><img src="{{ theme.link }}/assets/images/icons/footer-h1-2.png" alt=""></div>
    <div class="auto-container">

      {# Fila unica: logo | contacto | menu | logos extra #}
      <div class="row align-items-center footer-main-row gap-5">

        {# Logo del sitio #}
        <div class="footer-column col-12 col-lg-3">
          <div class="footer-widget about-widget wow fadeInLeft">
            <div class="footer-logo">
              {% if site_logo %}
                <img src="{{ site_logo.src }}" alt="{{ site.name }}">
              {% else %}
                <img src="{{ theme.link }}/assets/images/logo_respira_letras_cafe.png" alt="{{ site.name }}">
              {% endif %}
            </div>
          </div>
        </div>

        {# Contacto (telefono / email / redes) — alineado a la izquierda #}
        <div class="footer-column border-0 col-12 col-lg-3">
          <div class="footer-widget about-widget wow fadeInUp" data-wow-delay="200ms">
            <div class="widget-content">
              <div class="contact-area">
                <a class="phone" href="tel:{{ options.phone_tel }}">{{ options.phone }}</a>
                <a class="mail" href="mailto:{{ options.email }}">{{ options.email }}</a>
              </div>
              {% if options.socials %}
                <div class="social-widget mt-30">
                  <ul class="social-icon-list1 mb-0">
                    {% for s in options.socials %}
                      <li><a href="{{ s.link ?: '#' }}" target="_blank" rel="noopener noreferrer"><i class="{{ s.icon }}"></i></a></li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            </div>
          </div>
        </div>

        {# Menu (Enlaces) — alineado a la izquierda. Si el menú del footer no
           tiene elementos, no se muestra toda la columna. #}
        {% if menu_footer and menu_footer.items|length %}
          <div class="footer-column style-two border-0 col-12 col-lg-2">
            <div class="footer-widget links-widget wow fadeInUp" data-wow-delay="300ms">
              <div class="h5 widget-title">{{ __('Enlaces', 'respira') }}</div>
              <div class="widget-content">
                <ul class="user-links">
                  {% for item in menu_footer.items %}
                    <li><a href="{{ item.link }}">{{ item.title }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        {% endif %}

        {# Logos extra #}
        <div class="footer-column col-12 col-lg-4">
          <div class="footer-widget footer-images-widget wow fadeInRight" data-wow-delay="400ms">
            <div class="footer-images">
              {% if options.footer_image_1 %}
                <div class="footer-image footer-image--1"><img src="{{ options.footer_image_1 }}" alt=""></div>
              {% else %}
                <div class="footer-image footer-image--1 is-placeholder"></div>
              {% endif %}
              {% if options.footer_image_2 %}
                <div class="footer-image footer-image--2"><img src="{{ options.footer_image_2 }}" alt=""></div>
              {% else %}
                <div class="footer-image footer-image--2 is-placeholder"></div>
              {% endif %}
            </div>
          </div>
        </div>

      </div>

      <div class="footer-bottom">
        <div class="inner-container justify-content-center justify-content-sm-between">
          <p class="copyright-text">© {{ "now"|date("Y") }} {{ site.name }}. {{ __('Todos los derechos reservados.', 'respira') }}</p>
          <ul class="d-flex align-items-center gap-3">
            <li><a href="#0">{{ __('Politica de privacidad', 'respira') }}</a></li>
            <li><a href="#0">{{ __('Terminos del servicio', 'respira') }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

{#
  Layout maestro. Todas las plantillas extienden de aqui y rellenan {% block content %}.
  Estructura tomada de la plantilla Realest (page-wrapper, preloader, back-to-top).
#}
<!doctype html>
<html {{ site.language_attributes }}>
<head>
  <meta charset="{{ site.charset }}">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="shortcut icon" href="{{ theme.link }}/assets/images/favicon.png" type="image/x-icon">
  {{ function('wp_head') }}
</head>

<body class="{{ function('get_body_class')|join(' ') }}">
{{ function('wp_body_open') }}

<div class="page-wrapper">

  {# Preloader: desactivado en todo el sitio; se reactiva con RESPIRA_PRELOADER=true en wp-config.php #}
  {% if options.preloader %}
    <div class="preloader"></div>
  {% endif %}

  {# Back-to-top #}
  <div class="back-to-top-wrapper">
    <button id="back_to_top" type="button" class="back-to-top-btn">
      <svg width="12" height="7" viewBox="0 0 12 7" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11 6L6 1L1 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

  {# Botón flotante de WhatsApp (configurable en Personalizar → Respira) #}
  {% if options.whatsapp_url %}
    <a class="respira-wa-float" href="{{ options.whatsapp_url }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
      <i class="fab fa-whatsapp"></i>
    </a>
  {% endif %}

  {% include 'partials/header.twig' %}

  <main id="main">
    {% block content %}{% endblock %}
  </main>

  {% include 'partials/footer.twig' %}

</div>

{{ function('wp_footer') }}
</body>
</html>

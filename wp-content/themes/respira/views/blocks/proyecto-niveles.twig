{#
  Bloque: respira/proyecto-niveles — cuerpo "product-details" de Realest
  (galería de niveles + información), SIN estrellas ni precio.

  Galería propia (no bxSlider): una imagen activa + tira de miniaturas.
  La descripción de cada nivel se muestra al activar su miniatura; el
  comportamiento dinámico lo maneja assets/js/respira-proyectos.js.
#}
<div {{ wrapper_attributes|raw }}>
  <div class="product-details proyecto-niveles">
    <div class="row">

      <div class="col-lg-6 col-xl-6">
        {% if gallery %}
          <div class="proyecto-galeria">
            <div class="proyecto-galeria__stage">
              {% for g in gallery %}
                <figure class="image-box proyecto-slide{{ loop.first ? ' is-active' : '' }}" data-index="{{ loop.index0 }}">
                  <a href="{{ g.image }}" class="lightbox-image" data-fancybox="{{ uid }}"><img src="{{ g.image }}" alt="{{ g.alt }}"></a>
                </figure>
              {% endfor %}
            </div>
            {% if gallery|length > 1 %}
              <ul class="thumb-box list-unstyled clearfix">
                {% for g in gallery %}
                  <li><a class="{{ loop.first ? 'active' : '' }}" data-index="{{ loop.index0 }}" href="#"{% if g.name %} title="{{ g.name }}"{% endif %}><img src="{{ g.image }}" alt="{{ g.alt ?: g.name }}"></a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="col-lg-6 col-xl-6 product-info">
        {% if intro %}
          <div class="product-details__content proyecto-intro">{{ intro|raw }}</div>
        {% endif %}

        {% if gallery %}
          <div class="proyecto-descripciones">
            {% for g in gallery %}
              <div class="proyecto-descripcion product-details__content{{ loop.first ? ' is-active' : '' }}" data-index="{{ loop.index0 }}">
                {%- if g.name -%}
                  <h4 class="proyecto-nivel-titulo">{{ g.name }}</h4>
                {%- endif -%}
                {%- if g.descType in ['ul', 'ol'] -%}
                  <{{ g.descType }} class="proyecto-descripcion-lista">{{ g.description|raw }}</{{ g.descType }}>
                {%- else -%}
                  {{ g.description|raw }}
                {%- endif -%}
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if gallery %}
          <div class="proyecto-amenidades-niveles">
            {% for g in gallery %}
              <div class="product-description__list proyecto-amenidades-box proyecto-amenidades-nivel{{ loop.first ? ' is-active' : '' }}" data-index="{{ loop.index0 }}">
                {% if g.amenities %}
                  <ul class="list-unstyled proyecto-amenidades">
                    {% for a in g.amenities %}
                      <li><p>{% if a.imageUrl %}<img class="proyecto-amenidad-img" src="{{ a.imageUrl }}" alt="{{ a.imageAlt }}"> {% elseif a.icon %}<i class="{{ a.icon }}"></i> {% endif %}{{ a.text }}</p></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>

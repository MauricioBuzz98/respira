{#
  Bloque: respira/contact — markup contact-section de Realest.
  Izquierda: contenido (título + redes/contacto). Derecha: formulario.
  El formulario es un marcador visual estático (action="#"); el backend no está implementado.
#}
<section {{ wrapper_attributes|raw }}>
  <div class="contact-section mt-4">
    <div class="outer-box">
      <div class="auto-container">
        <div class="row align-items-center">

        <div class="info-column col-12 col-lg-5">
          <div class="contact-info-inner wow fadeInLeft">
            <div class="sec-title">
              {% if subtitle %}<div class="h6 sub-title">{{ subtitle }}</div>{% endif %}
              {% if title %}<div class="h2 title">{{ title }}</div>{% endif %}
              {% if text %}<div class="text">{{ text }}</div>{% endif %}
            </div>
            {% if socials %}
              <ul class="contact-social-list list-unstyled">
                {% for s in socials %}
                  <li>
                    <a href="{{ s.link ?: '#' }}" target="_blank" rel="noopener noreferrer">
                      <span class="icon">{% if s.icon %}<i class="{{ s.icon }}"></i>{% endif %}</span>
                      {% if s.text %}<span class="label">{{ s.text }}</span>{% endif %}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </div>

        <div class="form-coumn col-12 col-lg-7">
          <div class="inner-column">
            <div class="shape-1"><img src="{{ theme.link }}/assets/images/icons/shape-10.png" alt=""></div>
            <div class="form-box">
              <div class="inner-box">
                {% if form_html %}
                  <div class="respira-contact-shortcode">{{ form_html|raw }}</div>
                {% else %}
                  <form action="#">
                    <div class="row">
                      <div class="col-sm-6 wow fadeInUp animated" data-wow-delay=".2s">
                        <div class="form-clt">
                          <input type="text" name="name" id="name" placeholder="Tu nombre" required="">
                        </div>
                      </div>
                      <div class="col-sm-6 wow fadeInUp animated" data-wow-delay=".4s">
                        <div class="form-clt">
                          <input type="email" name="form_email" id="email" placeholder="Correo electrónico">
                        </div>
                      </div>
                      <div class="col-sm-6 wow fadeInUp animated" data-wow-delay=".6s">
                        <div class="form-clt">
                          <input name="tel" id="tel" type="text" placeholder="Teléfono">
                        </div>
                      </div>
                      <div class="col-sm-6 wow fadeInUp animated" data-wow-delay=".6s">
                        <div class="form-clt">
                          <input name="name" id="name2" type="text" placeholder="Asunto">
                        </div>
                      </div>
                      <div class="col-sm-12 wow fadeInUp animated" data-wow-delay=".2s">
                        <div class="form-clt">
                          <textarea name="form_message" class="required" placeholder="Mensaje"></textarea>
                        </div>
                      </div>
                      <div class="col-sm-12 wow fadeInUp animated" data-wow-delay=".2s">
                        <button class="theme-btn btn-style-three" type="submit">
                          <span class="btn-title">Enviar mensaje</span>
                        </button>
                      </div>
                    </div>
                  </form>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        </div>
      </div>
    </div>
  </div>
</section>

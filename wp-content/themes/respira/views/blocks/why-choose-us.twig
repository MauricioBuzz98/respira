{#
  Bloque: respira/why-choose-us — markup why-choose-us-section de Realest.
#}
<section {{ wrapper_attributes|raw }}>
  <div class="why-choose-us-section mt-4">
    <div class="outer-box">
      <div class="shape-1"><img src="{{ theme.link }}/assets/images/icons/shape-4.png" alt=""></div>

      <div class="image-column">
        <div class="image overflow-hidden">
          {% if imageUrl or mobileImageUrl or tabletImageUrl %}
            <picture>
              {% if mobileImageUrl %}<source media="(max-width: 767.98px)" srcset="{{ mobileImageUrl }}">{% endif %}
              {% if tabletImageUrl %}<source media="(min-width: 969px) and (max-width: 1439px)" srcset="{{ tabletImageUrl }}">{% endif %}
              <img src="{{ imageUrl ?: tabletImageUrl ?: mobileImageUrl }}" alt="{{ imageAlt ?: tabletImageAlt ?: mobileImageAlt }}">
            </picture>
          {% endif %}
        </div>
      </div>

      <div class="content-column">
        <div class="inner-column">
          <div class="sec-title light">
            {% if subtitle %}<div class="h6 sub-title">{{ subtitle }}</div>{% endif %}
            {% if title %}<div class="h2 title char-animation">{{ title }}</div>{% endif %}
          </div>

          {% if text %}
            <div class="text">{{ text|nl2br }}</div>
          {% endif %}

          {% if listItems %}
            <ul class="list-style-one">
              {% for item in listItems %}
                <li>
                  <i class="fa-solid fa-circle-check"></i>
                  <span>{{ item }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          {% if ctaUrl or ctaLabel %}
            <a class="theme-btn btn-style-two" href="{{ ctaUrl }}">
              <span class="icon">
                <i class="fa-solid fa-arrow-right"></i>
                <i class="fa-solid fa-arrow-right"></i>
              </span>
              <span class="btn-title">{{ ctaLabel }}</span>
            </a>
          {% endif %}

        </div>
      </div>
    </div>
  </div>
</section>

{#
  Bloque: respira/page-hero — hero editable de página.
  Imagen de fondo con overlay + subtítulo, título, texto y botón opcional.
#}
<section {{ wrapper_attributes|raw }} style="background-image: url({{ image }});">
  <div class="respira-page-hero__overlay"></div>
  <div class="auto-container">
    <div class="respira-page-hero__content">
      {% if subtitle %}<div class="h6 sub-title">{{ subtitle }}</div>{% endif %}
      {% if title %}<h1 class="title">{{ title }}</h1>{% endif %}
      {% if text %}<div class="text">{{ text|raw }}</div>{% endif %}
      {% if ctaLabel %}
        <a class="theme-btn btn-style-one" href="{{ ctaUrl ?: '#' }}">
          <span class="btn-title">{{ ctaLabel }}</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

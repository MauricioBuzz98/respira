{
  "name": "buzz/respira",
  "description": "Tema WordPress construido con Timber v2 (Twig) y bloques nativos de Gutenberg, adaptado de la plantilla Realest.",
  "type": "wordpress-theme",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "timber/timber": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Respira\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
